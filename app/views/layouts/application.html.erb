<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Escape Room" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script src="https://cdn.tailwindcss.com"></script>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100">
    <!-- Mensajes flash (notice/alert) -->
    <% if notice %>
      <p class="notice bg-green-100 text-green-800 p-4 text-center"><%= notice %></p>
    <% end %>
    <% if alert %>
      <p class="alert bg-red-100 text-red-800 p-4 text-center"><%= alert %></p>
    <% end %>

    <!-- Contenedor principal SIN flex (para evitar conflictos) -->
    <main class="min-h-screen">
      <%= yield %>
    </main>
  </body>
</html>