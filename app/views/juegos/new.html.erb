<% content_for :title, "Nuevo Juego" %>

<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">Nuevo Juego</h1>
    <div class="flex space-x-2">
      <%= link_to "Crear Sala", new_sala_path, class: "bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded transition duration-200" %>
      <%= link_to "Volver a Juegos", juegos_path, class: "bg-gray-500 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded transition duration-200" %>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <%= render "form", juego: @juego %>
  </div>

  <div class="mt-4">
    <%= link_to "← Volver a Juegos", juegos_path, class: "text-blue-500 hover:text-blue-700 font-medium" %>
  </div>
</div>
