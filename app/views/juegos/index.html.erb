<p class="text-green-600 font-semibold mb-4"><%= notice %></p>

<% content_for :title, "Juegos" %>

<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-800">Lista de Juegos</h1>
    <%= link_to new_juego_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-lg font-semibold rounded-lg shadow transition transform hover:scale-105" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Crear nuevo juego
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @juegos.each do |juego| %>
      <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
        <!-- Imagen del juego -->
        <div class="h-48 bg-gray-100 flex items-center justify-center">
          <% if juego.logo.attached? %>
            <% begin %>
              <%= image_tag juego.logo, class: "object-cover w-full h-full", loading: "lazy" %>
            <% rescue => e %>
              <div class="text-center p-4 text-red-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="mt-2 text-sm">Error al cargar la imagen</p>
              </div>
            <% end %>
          <% else %>
            <div class="text-center text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="mt-2">No hay imagen</p>
            </div>
          <% end %>
        </div>

        <!-- Contenido -->
        <div class="p-6">
          <h2 class="text-xl font-bold text-gray-800 mb-2 truncate"><%= juego.titulo %></h2>
          
          <div class="flex items-center mb-4">
            <span class="inline-block w-4 h-4 rounded-full mr-2" style="background-color: <%= juego.color_botones %>"></span>
            <span class="text-sm text-gray-600"><%= juego.color_botones %></span>
          </div>

          <div class="grid grid-cols-2 gap-2">
            <!-- Botón crear sala -->
            <%= link_to new_sala_path(juego_id: juego.id), class: "flex items-center justify-center gap-1 px-3 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              Sala
            <% end %>

            <!-- Botón ver salas -->
            <%= link_to salas_path(juego_id: juego.id), class: "flex items-center justify-center gap-1 px-3 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg text-sm transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h18" />
              </svg>
              Salas
            <% end %>

            <!-- Botón ver juego -->
            <%= link_to juego, class: "flex items-center justify-center gap-1 px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zm7.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Ver
            <% end %>

            <!-- Botón editar juego -->
            <%= link_to edit_juego_path(juego), class: "flex items-center justify-center gap-1 px-3 py-2 bg-orange-500 hover:bg-orange-600 text-white rounded-lg text-sm transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5M18.5 2.5l3 3L12 15l-4 1 1-4L18.5 2.5z" />
              </svg>
              Editar
            <% end %>

            <!-- Botón eliminar juego -->
            <%= link_to juego, method: :delete, data: { confirm: "¿Estás seguro de que quieres eliminar este juego?" }, class: "flex items-center justify-center gap-1 px-3 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5-4h4a1 1 0 011 1v2H9V4a1 1 0 011-1z" />
              </svg>
              Eliminar
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
