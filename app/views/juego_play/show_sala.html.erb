<div class="min-h-screen flex flex-col items-center justify-center bg-black text-gray-200 p-6">
  <h1 class="text-4xl font-bold mb-6 text-white">Sala <%= @sala.id %></h1>

  <!-- Imagen -->
  <% if @sala.imagen.attached? %>
    <%= image_tag @sala.imagen, class: "rounded-lg shadow-lg w-full max-w-3xl mb-6 border border-gray-700" %>
  <% end %>

  <!-- Botón para ver pistas -->
  <button onclick="togglePistas()" 
          class="mb-6 px-6 py-3 rounded-lg shadow transition transform hover:scale-105" 
          style="background-color: <%= @juego.color_botones %>; color: white;">
    Ver pistas
  </button>

  <!-- Pistas -->
  <div id="pistas" class="hidden bg-gray-800 p-4 rounded-lg border border-gray-700 mb-6 w-full max-w-3xl">
    <h2 class="text-lg font-semibold mb-2">Pistas:</h2>
    <ul class="list-disc list-inside text-gray-300 space-y-1">
      <% [@sala.pista1, @sala.pista2, @sala.pista3].reject(&:blank?).each do |pista| %>
        <li><%= pista %></li>
      <% end %>
    </ul>
  </div>

  <!-- Temporizador -->
  <div class="mb-6 text-2xl font-bold text-red-500" id="timer">
    ⏳ <span id="time"><%= @sala.tiempo %></span> segundos restantes
  </div>

  <!-- Formulario de respuestas -->
  <%= form_with url: usuario_jugar_path(@usuario, sala_index: params[:sala_index]), method: :post, local: true, class: "..." do |form| %>

    <% respuestas = [@sala.respuesta1, @sala.respuesta2, @sala.respuesta3].reject(&:blank?) %>

    <div class="flex flex-wrap justify-center gap-4 mb-6">
      <% respuestas.each_with_index do |_, index| %>
        <div class="flex flex-col">
          <%= form.label "Respuesta #{index + 1}", class: "mb-1 text-sm text-gray-400" %>
          <%= form.text_field "respuesta#{index + 1}", 
                class: "px-4 py-2 rounded-lg bg-gray-900 border border-gray-700 text-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-#{@juego.color_botones}" %>
        </div>
      <% end %>
    </div>

    <div class="flex justify-center">
      <%= form.submit "Enviar respuestas", 
            class: "px-6 py-3 rounded-lg shadow text-white transition transform hover:scale-105", 
            style: "background-color: #{@juego.color_botones};" %>
    </div>
  <% end %>
</div>

<script>
  let time = <%= @sala.tiempo %>;
  const timerEl = document.getElementById("time");

  const countdown = setInterval(() => {
    time--;
    timerEl.textContent = time;
    if (time <= 0) {
      clearInterval(countdown);
      window.location.href = "<%= juego_play_resultado_path %>?resultado=lose&usuario_id=<%= @usuario.id %>";





    }
  }, 1000);

  function togglePistas() {
    const pistas = document.getElementById("pistas");
    pistas.classList.toggle("hidden");
  }
</script>

