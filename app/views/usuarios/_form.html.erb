<div class="min-h-screen flex items-center justify-center bg-gray-100">
  <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-lg">
    <% if usuario.juego_id.present? %>
      <% juego = Juego.find(usuario.juego_id) %>
      <div class="flex justify-center mb-6">
        <% if juego.logo.present? %>
          <%= image_tag juego.logo, alt: juego.titulo, class: "h-30 object-contain" %>
        <% else %>
          <div class="text-center">
            <h3 class="text-xl font-semibold text-gray-800"><%= juego.titulo %></h3>
          </div>
        <% end %>
      </div>
    <% end %>

    <h2 class="text-3xl font-bold mb-6 text-center text-gray-800">
      Crear usuario
    </h2>

    <% if usuario.errors.any? %>
      <div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
        <h3 class="font-semibold">
          <%= pluralize(usuario.errors.count, "error") %> impidieron guardar el usuario:
        </h3>
        <ul class="list-disc pl-5 mt-2">
          <% usuario.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with(model: usuario, local: true, html: { class: "space-y-4" }) do |form| %>
      <div>
        <%= form.label :nombre, "Nombre completo", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :nombre, placeholder: "Ej: Juan Pérez", class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
      </div>

      <div>
        <%= form.label :correo, "Correo electrónico", class: "block text-sm font-medium text-gray-700" %>
        <%= form.email_field :correo, placeholder: "tucorreo@ejemplo.com", class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
      </div>

      <div>
        <%= form.label :cedula, "Celular", class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :cedula, placeholder: "Ej: 3001234567", class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
      </div>

      <% if usuario.juego_id.present? %>
        <div class="text-center">
          <p class="text-sm text-gray-600">
            <strong>Juego seleccionado:</strong>
            <%= juego.titulo %>
          </p>
          <%= form.hidden_field :juego_id, value: usuario.juego_id %>
        </div>
      <% else %>
        <div>
          <%= form.label :juego_id, "Seleccionar juego", class: "block text-sm font-medium text-gray-700" %>
          <%= form.collection_select :juego_id, Juego.all, :id, :titulo, { prompt: "Elige un juego" }, { class: "mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" } %>
        </div>
      <% end %>

      <div>
        <%= form.submit "Guardar usuario", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      </div>
    <% end %>
  </div>
</div>